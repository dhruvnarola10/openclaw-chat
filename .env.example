# OpenClaw Chat — environment variables
# Copy this file to .env and fill in your values.

# API endpoint (leave empty to use the Vite proxy default: /api/responses)
VITE_API_URL=

# Bearer token for OpenClaw API authentication
VITE_BEARER_TOKEN=

# Agent ID to target
VITE_AGENT_ID=main

# Model name passed in the request body
VITE_MODEL=openclaw

# Enable SSE streaming (true / false)
VITE_STREAM=true

# 32-character access token for the login screen (leave empty to disable login gate)
VITE_APP_TOKEN=

# ElevenLabs voice (real key goes in backend/.env as ELEVENLABS_API_KEY)
VITE_ELEVENLABS_ENABLED=true
VITE_ELEVENLABS_VOICE_ID=
VITE_ELEVENLABS_MODEL_ID=eleven_flash_v2_5
