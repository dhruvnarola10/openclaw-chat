# Backend API + Worker config. Copy to .env and fill in.

# HTTP
PORT=4000
NODE_ENV=production

# Auth — single shared bearer token for now. Same value used by the frontend.
APP_TOKEN=replace-with-a-long-random-string-at-least-32-chars

# Postgres (Docker)
DATABASE_URL=postgresql://leonardo:leonardo@127.0.0.1:5433/leonardo
POSTGRES_USER=leonardo
POSTGRES_PASSWORD=leonardo
POSTGRES_DB=leonardo

# Redis (Docker) — used by BullMQ for the worker queue
REDIS_URL=redis://127.0.0.1:6380

# OpenClaw gateway — backend dials this WS server-side to invoke methods
GATEWAY_WS_URL=ws://127.0.0.1:18789
GATEWAY_TOKEN=600a404a5a008c9f8c643a5a2f83b4529a6eae0d46ebc131

# CORS — origins allowed to call this API. Same-origin via nginx is fine
# without listing anything; add explicit entries if calling from elsewhere.
ALLOWED_ORIGINS=https://leonardoai.grassurntech.com,http://localhost:3001

# Worker (when running in Docker, use host.docker.internal so it can reach
# the gateway and (if needed) the API on the host)
WORKER_GATEWAY_WS_URL=ws://host.docker.internal:18789
WORKER_REDIS_URL=redis://redis:6379
WORKER_DATABASE_URL=postgresql://leonardo:leonardo@postgres:5432/leonardo

# ElevenLabs platform TTS key (server-side only)
ELEVENLABS_API_KEY=
